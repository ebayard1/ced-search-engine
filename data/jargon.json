{
  "_comment": "Digitized counter cheat sheet. Each rule: terms the counter hears -> mfr + catalog regex. 'hint' explains the numbering so you learn it. Add your own rules at the bottom; they're picked up on server restart.",
  "rules": [
    { "term": "EMT set screw connector", "aliases": ["set screw connector", "ss emt connector", "emt connector"], "mfr": "BPT", "match": "^23\\d", "hint": "BPT 23X. Last digit = size: 0=1/2\", 1=3/4\", 2=1\", 3=1-1/4\", 4=1-1/2\", 5=2\", 6=2-1/2\", 7=3\", 9=4\". 'I' suffix = insulated throat, 'SR' = reducing." },
    { "term": "EMT set screw coupling", "aliases": ["set screw coupling", "ss emt coupling", "emt coupling"], "mfr": "BPT", "match": "^24\\d", "hint": "BPT 24X, same size digits as the 23X connectors." },
    { "term": "EMT compression connector", "aliases": ["compression connector", "comp connector"], "mfr": "BPT", "match": "^25\\d", "hint": "BPT 25X. Compression = raintight/concrete-tight, use outdoors or where set screw isn't allowed." },
    { "term": "EMT compression coupling", "aliases": ["compression coupling", "comp coupling"], "mfr": "BPT", "match": "^26\\d", "hint": "BPT 26X, same size digits." },
    { "term": "sealtight connector straight", "aliases": ["seal tight connector", "sealtite connector", "liquidtight connector", "liquid tight connector", "lt connector"], "mfr": "BPT", "match": "^43\\d", "hint": "BPT 43X + suffix: SLTI = steel, LTI2 = die cast, NMLT = non-metallic. For liquidtight flexible conduit." },
    { "term": "sealtight connector 90", "aliases": ["seal tight 90", "sealtite 90", "liquidtight 90", "lt 90 connector"], "mfr": "BPT", "match": "^47\\d", "hint": "BPT 47X + SLTI/NMLT suffixes, 90-degree version of the 43X." },
    { "term": "screw-in metal flex connector", "aliases": ["screw in flex connector", "flex connector", "greenfield connector"], "mfr": "BPT", "match": "^52\\d", "hint": "BPT 52X. Screws into the flex (greenfield) convolutions." },
    { "term": "metal flex 90 connector", "aliases": ["flex 90", "greenfield 90"], "mfr": "BPT", "match": "^80\\d", "hint": "BPT 80X, 90-degree flex connector." },
    { "term": "4 square box", "aliases": ["four square box", "4s box", "1900 box", "4 square"], "mfr": "ORBUM", "match": "^4S[BD]", "hint": "ORBUM 4SB-MKO = standard 1-1/2\" deep, 4SDB-MKO = deep 2-1/8\". MKO = mixed knockouts." },
    { "term": "1-hole strap rigid", "aliases": ["one hole strap rigid", "rigid strap"], "mfr": "BPT", "match": "^90\\d", "hint": "BPT 90X for rigid/GRC." },
    { "term": "1-hole strap EMT", "aliases": ["one hole strap emt", "emt strap", "one hole strap"], "mfr": "BPT", "match": "^92\\d", "hint": "BPT 92X for EMT." },
    { "term": "mineralac strap", "aliases": ["minis", "mineralac", "minnie", "conduit hanger"], "mfr": "BPT", "match": "^21\\d0?BN", "hint": "BPT 21X0BN — 'minis'. Hangs conduit off strut/rod. 2100BN=1/2\", 2110BN=3/4\", 2120BN=1\"..." },
    { "term": "1-gang bell box weatherproof", "aliases": ["bell box", "weatherproof box", "wp box", "1g bell box"], "mfr": "ORBUM", "match": "^1D?B\\d", "hint": "ORBUM 1Bxxx (e.g. 1B755 = five 3/4\" holes). 1DBxxx = deep (e.g. 1DB503). Digits: first = hub size (5=1/2\", 7=3/4\", 10=1\"), last = number of holes." },
    { "term": "2-gang bell box weatherproof", "aliases": ["2g bell box", "2 gang weatherproof box"], "mfr": "ORBUM", "match": "^2D?B\\d", "hint": "ORBUM 2Bxxx / 2DBxxx (deep), same hub-size digits as 1-gang." },
    { "term": "handy box", "aliases": ["utility box", "handybox"], "mfr": "ORBUM", "match": "^D?HB", "hint": "ORBUM HB = handy box, DHB = deep handy box (e.g. DHB150)." },
    { "term": "plastic cut-in box", "aliases": ["cut in box", "old work box", "remodel box"], "mfr": "CANTX", "match": "^EZ\\d+S?O", "hint": "CANTX EZ14SO / EZ18SO = plastic cut-in (old work). Wings grab the drywall." },
    { "term": "plastic nail-on box", "aliases": ["nail on box", "new work box"], "mfr": "CANTX", "match": "^EZ\\d+[SC]N", "hint": "CANTX EZ18SNW = 1-gang plastic nail-on (new work), EZ18CN = round nail-on." },
    { "term": "metal cut-in box tiger grip", "aliases": ["tiger grip box", "metal cut in box", "tiger box"], "mfr": "ORBUM", "match": "^TG", "hint": "ORBUM TG1 — metal old-work box with tiger-grip clamps." },
    { "term": "telescoping bracket", "aliases": ["telescope bracket", "sliding bracket", "box bracket", "far side support"], "mfr": "BLINE", "match": "^BB\\d+T?", "hint": "BLINE BB2XXT (BB216T = 16\" stud bay, BB224T = 24\"). Cross-ref: Caddy TSGB16/24." },
    { "term": "duplex outlet tamper resistant 15A", "aliases": ["tr duplex", "tamper resistant outlet", "15a outlet", "duplex receptacle"], "mfr": "PS", "match": "^3232TR", "hint": "PS 3232TRW (white). Leviton equivalent: T5320W." },
    { "term": "duplex outlet tamper resistant 15A leviton", "aliases": ["leviton tr duplex"], "mfr": "LEV", "match": "^T5320", "hint": "LEV T5320W = 15A TR duplex, white." },
    { "term": "duplex outlet 20A non tamper resistant", "aliases": ["20a duplex", "20a outlet", "cr20"], "mfr": "PS", "match": "^CR20", "hint": "CR20W — both PS and Leviton use CR20. 20A commercial-grade duplex, NEMA 5-20R." },
    { "term": "duplex outlet 20A leviton", "aliases": ["leviton 20a duplex"], "mfr": "LEV", "match": "^CR20", "hint": "LEV CR20W, same number as PS." },
    { "term": "GFCI outlet tamper resistant 15A", "aliases": ["gfci 15", "gfi 15", "15a gfci", "gfci outlet"], "mfr": "PS", "match": "^1597TR", "hint": "PS 1597TRW. Leviton equivalent: GFTR1W." },
    { "term": "GFCI 15A leviton", "aliases": ["leviton gfci 15"], "mfr": "LEV", "match": "^GFTR1", "hint": "LEV GFTR1W = 15A TR GFCI, white." },
    { "term": "GFCI outlet tamper resistant 20A", "aliases": ["gfci 20", "gfi 20", "20a gfci"], "mfr": "PS", "match": "^2097TR", "hint": "PS 2097TRW. Leviton equivalent: GFTR2W." },
    { "term": "GFCI 20A leviton", "aliases": ["leviton gfci 20"], "mfr": "LEV", "match": "^GFTR2", "hint": "LEV GFTR2W = 20A TR GFCI, white." },
    { "term": "duplex outlet cover", "aliases": ["duplex cover", "outlet cover", "receptacle plate", "duplex plate"], "mfr": "PS", "match": "^TP8", "hint": "PS TP8W (nylon, white). Leviton equivalent: PJ8W." },
    { "term": "duplex cover leviton", "aliases": ["leviton duplex cover"], "mfr": "LEV", "match": "^PJ8", "hint": "LEV PJ8W." },
    { "term": "decora 15A switch", "aliases": ["decora switch", "rocker switch", "paddle switch"], "mfr": "PS", "match": "^TM87", "hint": "PS TM87XW. Leviton rockers: 56012W (single pole), 56032W (3-way), 56042W (4-way)." },
    { "term": "decora switch leviton", "aliases": ["leviton rocker switch", "leviton decora"], "mfr": "LEV", "match": "^560\\d2", "hint": "LEV 560X2W — X: 1=single pole, 3=three-way, 4=four-way." },
    { "term": "decora or GFCI cover", "aliases": ["decora cover", "gfci cover", "gfi plate", "decora plate"], "mfr": "PS", "match": "^TP26", "hint": "PS TP26W. Leviton equivalent: PJ26W." },
    { "term": "decora cover leviton", "aliases": ["leviton decora cover"], "mfr": "LEV", "match": "^PJ26", "hint": "LEV PJ26W." },
    { "term": "junction box screw cover", "aliases": ["jbox", "j box", "junction box", "pull box", "screw cover box"], "mfr": "BLINE", "match": "SCNK$", "hint": "BLINE {W}{H}{D}SCNK, e.g. 664SCNK = 6x6x4 NEMA 1. RTSCNK = raintight NEMA 3R (664RTSCNK). Size digits are inches." },
    { "term": "weatherproof junction box 3R", "aliases": ["weatherproof jbox", "3r jbox", "raintight junction box", "outdoor junction box"], "mfr": "BLINE", "match": "RTSCNK$", "hint": "BLINE ...RTSCNK = NEMA 3R screw cover. 664RTSCNK = 6x6x4." },
    { "term": "EMT elbow 90", "aliases": ["emt 90", "emt elbow", "emt sweep"], "mfr": "FIT", "match": "^ELEMT", "hint": "FIT ELEMT + size (ELEMT-3/4, ELEMT1-1/2). Trailing 22/30/45 = degree if not 90." },
    { "term": "rigid elbow 90", "aliases": ["rigid 90", "grc elbow", "rigid sweep"], "mfr": "FIT", "match": "^ELGAL", "hint": "FIT ELGAL + size. GAL = galvanized rigid." },
    { "term": "rigid coupling", "aliases": ["grc coupling", "threaded coupling"], "mfr": "FIT", "match": "^CPLGAL", "hint": "FIT CPLGAL + size." },
    { "term": "PVC elbow", "aliases": ["pvc 90", "pvc sweep", "pvc ell"], "mfr": "PVC", "match": "^EL", "hint": "PVC EL + size (+degree for 22/45)." },
    { "term": "PVC male adapter", "aliases": ["male adapter", "pvc ma", "terminal adapter"], "mfr": "PVC", "match": "^TA", "hint": "PVC TA + size. TA = terminal (male) adapter — glues on pipe, threads into box/hub." },
    { "term": "PVC female adapter", "aliases": ["female adapter", "pvc fa"], "mfr": "PVC", "match": "^FA", "hint": "PVC FA + size. Glue socket one end, female threads the other." },
    { "term": "PVC bell end", "aliases": ["bell end", "pvc bell"], "mfr": "PVC", "match": "^BE", "hint": "PVC BE + size. Flared end where conductors leave the conduit (e.g. in a vault or trench stub-up)." },
    { "term": "PVC repair coupling", "aliases": ["repair coupling", "slip coupling", "slip fix"], "mfr": "PVC", "match": "^CPLR", "hint": "PVC CPLR + size. No center stop, slides fully onto pipe to repair a cut section." },
    { "term": "PVC deep socket coupling", "aliases": ["deep socket coupling"], "mfr": "PVC", "match": "^CPLDEEPSOCKET", "hint": "PVC CPLDEEPSOCKETX." },
    { "term": "chase nipple", "aliases": ["chase nip", "bushed nipple"], "mfr": "BPT", "match": "^11\\d{2}", "hint": "BPT 11XX. DCI suffix = insulated bushed nipple." },
    { "term": "close nipple", "aliases": ["rigid nipple", "conduit nipple"], "mfr": "FIT", "match": "^NIPGAL", "hint": "FIT NIPGAL + size + length." },
    { "term": "250 volt fuse", "aliases": ["250v fuse", "flnr fuse", "rk5 fuse 250"], "mfr": "LF", "match": "^FLNR", "hint": "Littelfuse FLNR + amps (FLNR020 = 20A). Class RK5 time-delay, 250V." },
    { "term": "600 volt fuse", "aliases": ["600v fuse", "flsr fuse", "rk5 fuse 600"], "mfr": "LF", "match": "^FLSR", "hint": "Littelfuse FLSR + amps. Class RK5 time-delay, 600V." },
    { "term": "snap-in MC connector", "aliases": ["snap in connector", "mc connector", "snap2it", "snap 2 it"], "mfr": "ARL", "match": "^40\\d*AST|^4040", "hint": "Arlington 40AST (single), 4040AST, 404010AST (duplex). Push in, no locknut." },
    { "term": "ground bushing", "aliases": ["bond bushing", "grounding bushing", "bonding bushing"], "mfr": "BPT", "match": "^38\\d", "hint": "BPT 38X — insulated grounding bushing with lug." }
  ]
}
